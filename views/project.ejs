<%- include('partials/head') %>

<%- include('partials/nav') %>

<main>
  <section class="project-hero" id="projectHero">
    <div class="project-hero-slider" id="heroSlider">
      <% var useVideos = project.heroVideos && project.heroVideos.length; %>
      <% var slides = useVideos ? project.heroVideos : (project.heroImages && project.heroImages.length ? project.heroImages : ['/images/hero-bg.jpg']); %>
      <% slides.forEach(function(src, i) { %>
      <div class="project-hero-slide <%= i === 0 ? 'active' : '' %>" data-slide="<%= i %>">
        <% if (useVideos) { %>
        <video class="hero-slide-video" muted loop playsinline poster="<%= project.heroImages && project.heroImages[i] ? project.heroImages[i] : '' %>">
          <source src="<%= src %>" type="video/mp4">
        </video>
        <% } else { %>
        <div class="hero-slide-img" style="background-image: url('<%= src %>')"></div>
        <% } %>
        <div class="project-hero-overlay"></div>
      </div>
      <% }) %>
    </div>
    <div class="project-hero-dots" id="heroDots">
      <% slides.forEach(function(_, i) { %>
      <button class="hero-dot <%= i === 0 ? 'active' : '' %>" data-slide="<%= i %>"></button>
      <% }) %>
    </div>
    <div class="container project-hero-content">
      <div class="project-hero-text">
        <span class="eyebrow"><%= project.name %></span>
        <h1><%= project.tagline || '' %></h1>
        <p><%= project.location %></p>
        <div class="project-hero-tags">
          <span><%= project.type %></span>
          <span><%= project.status %></span>
        </div>
      </div>
      <div class="project-enquiry-card">
        <h3>Quick Enquiry</h3>
        <form id="projectEnquiryForm">
          <input type="hidden" name="project" value="<%= project.name %>">
          <input type="text" name="name" placeholder="Your Name" required>
          <input type="tel" name="phone" placeholder="Phone Number" required>
          <button type="submit" class="btn btn-gold btn-block">Enquire Now</button>
        </form>
        <div class="enquiry-msg" id="enquiryMsg"></div>
        <p class="enquiry-contact">or call <a href="tel:<%= project.contact.phone %>"><%= project.contact.phone %></a></p>
      </div>
    </div>
  </section>

  <section class="project-stats">
    <div class="container">
      <div class="stats-strip">
        <div class="stat-item"><span class="stat-val"><%= project.floors || '—' %></span><span class="stat-lbl">Floors</span></div>
        <div class="stat-item"><span class="stat-val"><%= project.units %></span><span class="stat-lbl">Units</span></div>
        <div class="stat-item"><span class="stat-val"><%= project.penthouse ? '2' : '—' %></span><span class="stat-lbl">Penthouses</span></div>
        <div class="stat-item"><span class="stat-val"><%= project.builtup %></span><span class="stat-lbl">Max Built-up</span></div>
        <div class="stat-item"><span class="stat-val"><%= project.price %></span><span class="stat-lbl">Starting Price</span></div>
      </div>
    </div>
  </section>

  <section class="project-about section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image reveal">
          <% var aboutImg = project.gallery && project.gallery.length ? project.gallery[0] : ''; %>
          <div class="about-img"<% if (aboutImg) { %> style="background-image: url('<%= aboutImg %>')"<% } %>></div>
        </div>
        <div class="about-text reveal">
          <span class="eyebrow">About</span>
          <h2 class="section-title"><%= project.name %></h2>
          <p><%= project.about %></p>
          <ul class="about-highlights">
            <% project.highlights.forEach(function(h) { %>
            <li><%= h %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <% if (project.units && project.units.length) { %>
  <section class="project-units section-dark" id="units">
    <div class="container">
      <span class="eyebrow">Our Residences</span>
      <h2 class="section-title">Choose Your <em>Home</em></h2>
      <div class="units-grid">
        <% project.units.forEach(function(unit) { %>
        <div class="unit-card reveal <%= unit.featured ? 'unit-featured' : '' %>">
          <% if (unit.featured) { %><span class="unit-badge">Most Popular</span><% } %>
          <h3><%= unit.type %></h3>
          <p class="unit-desc"><%= unit.description %></p>
          <div class="unit-meta">
            <span class="unit-size"><%= unit.size %></span>
            <span class="unit-price"><%= unit.price %></span>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <% if (project.floorPlans && project.floorPlans.length) { %>
  <section class="project-floorplans section" id="floorplans">
    <div class="container">
      <span class="eyebrow">Floor Plans</span>
      <h2 class="section-title">Explore the <em>Layout</em></h2>
      <div class="floorplan-tabs">
        <% project.floorPlans.forEach(function(fp, i) { %>
        <button class="floorplan-tab <%= i === 0 ? 'active' : '' %>" data-tab="<%= i %>"><%= fp.name %></button>
        <% }) %>
      </div>
      <div class="floorplan-display">
        <% project.floorPlans.forEach(function(fp, i) { %>
        <div class="floorplan-panel <%= i === 0 ? 'active' : '' %>" data-panel="<%= i %>">
          <div class="floorplan-image-wrapper">
            <div class="floorplan-image" style="background-image: url('<%= fp.image %>')">
              <div class="floorplan-label"><%= fp.name %></div>
            </div>
            <div class="floorplan-hint">Click to view full size</div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <section class="project-amenities section-dark" id="amenities">
    <div class="container">
      <span class="eyebrow">Amenities</span>
      <h2 class="section-title">Designed for <em>Luxury Living</em></h2>
      <div class="amenities-grid">
        <% project.amenities.forEach(function(a) { %>
        <div class="amenity-card reveal">
          <div class="amenity-icon">
            <% if (a.icon === 'camera') { %><svg viewBox="0 0 48 48" fill="none"><rect x="6" y="14" width="36" height="26" rx="2" stroke="#C9A262" stroke-width="1.5"/><circle cx="24" cy="27" r="8" stroke="#C9A262" stroke-width="1.5"/><circle cx="24" cy="27" r="3" fill="#C9A262"/></svg>
            <% } else if (a.icon === 'elevator') { %><svg viewBox="0 0 48 48" fill="none"><rect x="10" y="4" width="28" height="40" rx="2" stroke="#C9A262" stroke-width="1.5"/><path d="M20 16L24 10L28 16" stroke="#C9A262" stroke-width="1.5"/><path d="M20 32L24 38L28 32" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'zap') { %><svg viewBox="0 0 48 48" fill="none"><path d="M26 4L14 26H22L20 44L36 20H28L30 4H26Z" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'compass') { %><svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="20" stroke="#C9A262" stroke-width="1.5"/><path d="M24 4V8" stroke="#C9A262" stroke-width="1.5"/><path d="M24 40V44" stroke="#C9A262" stroke-width="1.5"/><path d="M4 24H8" stroke="#C9A262" stroke-width="1.5"/><path d="M40 24H44" stroke="#C9A262" stroke-width="1.5"/><circle cx="24" cy="24" r="6" fill="#C9A262"/></svg>
            <% } else if (a.icon === 'tree') { %><svg viewBox="0 0 48 48" fill="none"><path d="M24 4L12 24H36L24 4Z" stroke="#C9A262" stroke-width="1.5"/><path d="M14 24L8 34H40L34 24" stroke="#C9A262" stroke-width="1.5"/><line x1="24" y1="34" x2="24" y2="44" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'map-pin') { %><svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="18" r="14" stroke="#C9A262" stroke-width="1.5"/><path d="M24 32L24 44" stroke="#C9A262" stroke-width="1.5"/><circle cx="24" cy="18" r="5" fill="#C9A262"/></svg>
            <% } else if (a.icon === 'truck') { %><svg viewBox="0 0 48 48" fill="none"><rect x="4" y="14" width="26" height="20" rx="2" stroke="#C9A262" stroke-width="1.5"/><rect x="24" y="14" width="20" height="16" rx="2" stroke="#C9A262" stroke-width="1.5"/><circle cx="14" cy="36" r="4" stroke="#C9A262" stroke-width="1.5"/><circle cx="36" cy="36" r="4" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'shield') { %><svg viewBox="0 0 48 48" fill="none"><path d="M24 4L6 12V24C6 34 14 42 24 44C34 42 42 34 42 24V12L24 4Z" stroke="#C9A262" stroke-width="1.5"/><path d="M18 24L22 28L30 20" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'droplet') { %><svg viewBox="0 0 48 48" fill="none"><path d="M24 4C24 4 10 22 10 30C10 37.732 16.268 44 24 44C31.732 44 38 37.732 38 30C38 22 24 4 24 4Z" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else if (a.icon === 'sun') { %><svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="8" stroke="#C9A262" stroke-width="1.5"/><path d="M24 4V8" stroke="#C9A262" stroke-width="1.5"/><path d="M24 40V44" stroke="#C9A262" stroke-width="1.5"/><path d="M4 24H8" stroke="#C9A262" stroke-width="1.5"/><path d="M40 24H44" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } else { %><svg viewBox="0 0 48 48" fill="none"><rect x="8" y="8" width="32" height="32" rx="4" stroke="#C9A262" stroke-width="1.5"/></svg>
            <% } %>
          </div>
          <span class="amenity-name"><%= a.name %></span>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <% var specs = project.specifications; %>
  <% if (specs && Object.values(specs).some(s => s.length)) { %>
  <section class="project-specs section" id="specs">
    <div class="container">
      <span class="eyebrow">Specifications</span>
      <h2 class="section-title">Built to <em>Perfection</em></h2>
      <div class="specs-grid">
        <% Object.entries(specs).forEach(function(cat) { var catName = cat[0]; var items = cat[1]; %>
        <% if (items.length) { %>
        <div class="spec-card reveal">
          <h3><%= catName %></h3>
          <ul>
            <% items.forEach(function(item) { %>
            <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
        <% } %>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <% if (project.gallery && project.gallery.length) { %>
  <section class="project-gallery section-dark" id="gallery">
    <div class="container">
      <span class="eyebrow">Gallery</span>
      <h2 class="section-title">A Glimpse of <em>Perfection</em></h2>
      <div class="gallery-grid">
        <% project.gallery.forEach(function(img) { %>
        <div class="gallery-item reveal">
          <div class="gallery-image" style="background-image: url('<%= img %>')"></div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <section class="project-location section" id="location">
    <div class="container">
      <span class="eyebrow">Location</span>
      <h2 class="section-title">Prime <em>Connectivity</em></h2>
      <div class="location-grid">
        <div class="location-map reveal">
          <div class="expand-map" id="expandMap">
            <div class="expand-map-inner" id="expandMapInner">
              <div class="expand-map-gradient"></div>

              <div class="expand-map-roads" id="expandRoads">
                <svg viewBox="0 0 400 320" width="100%" height="100%">
                  <defs>
                    <radialGradient id="pinGlow" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#2A9D6F" stop-opacity="0.35"/>
                      <stop offset="100%" stop-color="#2A9D6F" stop-opacity="0"/>
                    </radialGradient>
                    <linearGradient id="roadGrad" x1="0" y1="0" x2="1" y2="0">
                      <stop offset="0%" stop-color="#C9A262" stop-opacity="0.3"/>
                      <stop offset="50%" stop-color="#C9A262" stop-opacity="0.7"/>
                      <stop offset="100%" stop-color="#C9A262" stop-opacity="0.3"/>
                    </linearGradient>
                    <radialGradient id="warmGlow" cx="50%" cy="50%" r="60%">
                      <stop offset="0%" stop-color="#F8F4EE" stop-opacity="0"/>
                      <stop offset="70%" stop-color="#F8F4EE" stop-opacity="0"/>
                      <stop offset="100%" stop-color="#1C1D5E" stop-opacity="0.03"/>
                    </radialGradient>
                  </defs>

                  <!-- Warm ambient glow -->
                  <rect width="400" height="320" fill="url(#warmGlow)"/>

                  <!-- Abstract road network -->
                  <path d="M 0,180 Q 200,155 400,180" stroke="url(#roadGrad)" stroke-width="3" fill="none"/>
                  <path d="M 0,180 Q 200,155 400,180" stroke="#C9A262" stroke-width="1" stroke-dasharray="6 4" opacity="0.3" fill="none"/>
                  <path d="M 200,20 L 200,310" stroke="rgba(201,162,98,0.15)" stroke-width="1.5" fill="none"/>
                  <path d="M 50,40 L 370,290" stroke="rgba(28,29,94,0.06)" stroke-width="1" fill="none"/>
                  <path d="M 80,300 L 350,30" stroke="rgba(28,29,94,0.06)" stroke-width="1" fill="none"/>
                  <path d="M 40,180 L 200,40 L 360,180" stroke="rgba(201,162,98,0.08)" stroke-width="0.8" fill="none"/>
                  <path d="M 40,200 L 200,300 L 370,210" stroke="rgba(201,162,98,0.08)" stroke-width="0.8" fill="none"/>

                  <!-- Abstract building clusters -->
                  <rect x="60" y="50" width="35" height="22" rx="3" fill="rgba(201,162,98,0.08)" stroke="rgba(201,162,98,0.15)" stroke-width="0.5"/>
                  <rect x="110" y="60" width="20" height="15" rx="2" fill="rgba(28,29,94,0.05)" stroke="rgba(28,29,94,0.08)" stroke-width="0.5"/>
                  <rect x="280" y="210" width="45" height="28" rx="3" fill="rgba(201,162,98,0.08)" stroke="rgba(201,162,98,0.15)" stroke-width="0.5"/>
                  <rect x="310" y="80" width="25" height="35" rx="3" fill="rgba(28,29,94,0.05)" stroke="rgba(28,29,94,0.08)" stroke-width="0.5"/>
                  <rect x="90" y="240" width="30" height="18" rx="2" fill="rgba(201,162,98,0.06)" stroke="rgba(201,162,98,0.12)" stroke-width="0.5"/>
                  <rect x="150" y="260" width="40" height="22" rx="3" fill="rgba(28,29,94,0.05)" stroke="rgba(28,29,94,0.08)" stroke-width="0.5"/>

                  <!-- Green patches -->
                  <circle cx="140" cy="130" r="30" fill="rgba(42,157,111,0.06)"/>
                  <circle cx="320" cy="150" r="25" fill="rgba(42,157,111,0.05)"/>
                  <circle cx="80" cy="280" r="20" fill="rgba(42,157,111,0.04)"/>

                  <!-- Decorative dots -->
                  <circle cx="45" cy="185" r="1.5" fill="rgba(201,162,98,0.2)"/>
                  <circle cx="365" cy="175" r="1.5" fill="rgba(201,162,98,0.2)"/>
                  <circle cx="200" cy="25" r="1" fill="rgba(201,162,98,0.15)"/>
                  <circle cx="200" cy="305" r="1" fill="rgba(201,162,98,0.15)"/>

                  <!-- Pin glow -->
                  <circle cx="200" cy="150" r="35" fill="url(#pinGlow)"/>
                </svg>
              </div>

              <div class="expand-map-pin" id="expandPin">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#2A9D6F"/>
                  <circle cx="12" cy="9" r="2.5" fill="#F8F4EE"/>
                </svg>
              </div>
              <div class="expand-map-pin-ring"></div>

              <div class="expand-map-vignette"></div>

              <div class="expand-map-grid" id="expandGrid">
                <svg width="100%" height="100%">
                  <defs>
                    <pattern id="grid-pattern" width="20" height="20" patternUnits="userSpaceOnUse">
                      <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#1C1D5E" stroke-width="0.3" opacity="0.15"/>
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#grid-pattern)"/>
                </svg>
              </div>

              <div class="expand-map-content">
                <div class="expand-map-top">
                  <div class="expand-map-icon" id="expandIcon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
                      <line x1="9" y1="3" x2="9" y2="18"/>
                      <line x1="15" y1="6" x2="15" y2="21"/>
                    </svg>
                  </div>
                  <div class="expand-map-badge">
                    <span class="badge-dot"></span>
                    <span>Live</span>
                  </div>
                </div>
                <div class="expand-map-bottom">
                  <h3 class="expand-map-name" id="expandName"><%= project.location.address || project.location %></h3>
                  <p class="expand-map-coords" id="expandCoords">NH-4 · School · Hospital · Mall · Garden</p>
                  <div class="expand-map-line"></div>
                </div>
              </div>
            </div>
            <p class="expand-map-hint">Click to expand</p>
          </div>
          <div class="landmark-badges">
            <% if (project.location && project.location.mapPoints && project.location.mapPoints.length) { %>
            <% var iconMap = {
              'National Highway': 'M3 6l6-3 6 3 6-3v15l-6 3-6-3-6 3V6z',
              'Love Dale Central School': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
              'KLE Hospital': 'M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z',
              'Belagavi Upcoming Mall': 'M3 21h18M3 10h18M5 6l7-4 7 4M4 10v11M20 10v11M8 14v7M16 14v7M12 14v7',
              'Sector No. 12 Garden': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
              'Railway Station': 'M4 4h16v16H4V4zM4 9h16M8 4v5M16 4v5M8 13v4M16 13v4',
            }; %>
            <% project.location.mapPoints.forEach(function(pt) { %>
            <% var parts = pt.split(' — '); var name = parts[0]; var dist = parts[1]; %>
            <div class="landmark-badge">
              <div class="badge-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="#C9A262" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <% var found = false; for (var key in iconMap) { if (name.indexOf(key) > -1) { found = true; %>
                  <path d="<%= iconMap[key] %>"/>
                  <% }} if (!found) { %>
                  <circle cx="12" cy="12" r="10"/>
                  <% } %>
                </svg>
              </div>
              <div class="badge-text">
                <span class="badge-name"><%= name %></span>
                <span class="badge-dist"><%= dist %></span>
              </div>
            </div>
            <% }) %>
            <% } %>
          </div>
        </div>
        <div class="location-info reveal">
          <h3><%= project.location.address || project.location %></h3>
          <% if (project.location && project.location.mapPoints && project.location.mapPoints.length) { %>
          <ul class="location-points">
            <% project.location.mapPoints.forEach(function(pt) { %>
            <li><%= pt %></li>
            <% }) %>
          </ul>
          <% } %>

        </div>
      </div>
    </div>
  </section>

  <section class="project-contact section-dark" id="projectContact">
    <div class="container">
      <span class="eyebrow">Get in Touch</span>
      <h2 class="section-title">Book Your <em>Site Visit</em></h2>
      <div class="contact-project-grid">
        <div class="contact-project-info">
          <div class="contact-person">
            <h3><%= project.contact.name %></h3>
            <a href="tel:<%= project.contact.phone %>"><%= project.contact.phone %></a>
            <a href="mailto:<%= project.contact.email %>"><%= project.contact.email %></a>
            <p class="contact-website"><%= project.contact.website %></p>
          </div>
        </div>
        <form class="contact-project-form" id="projectContactForm">
          <input type="hidden" name="project" value="<%= project.name %>">
          <div class="form-row">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="tel" name="phone" placeholder="Phone Number" required>
          </div>
          <div class="form-row">
            <input type="email" name="email" placeholder="Email (optional)">
            <input type="text" name="units" placeholder="Unit Type (1 BHK / 2 BHK)">
          </div>
          <textarea name="message" rows="3" placeholder="Your Message"></textarea>
          <button type="submit" class="btn btn-gold">Book a Site Visit</button>
          <div class="form-msg" id="projectFormMsg"></div>
        </form>
      </div>
    </div>
  </section>

  <% if (project.rera) { %>
  <div class="rera-bar">
    <div class="container">
      <p>RERA Registration No.: <%= project.rera %></p>
    </div>
  </div>
  <% } %>
</main>

<%- include('partials/footer') %>
